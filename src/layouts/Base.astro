---
import BaseHead from "../components/BaseHead.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";

interface Props {
  title?: string;
  description?: string;
}

const { title = SITE_TITLE, description = SITE_DESCRIPTION } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <div id="scroll-progress" class="scroll-progress"></div>
    <canvas id="cursor-trail" class="cursor-trail-canvas"></canvas>

    <slot />

    <button id="back-to-top" class="glass back-to-top" aria-label="Back to top">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="18 15 12 9 6 15"></polyline>
      </svg>
    </button>

    <style is:global>
      .scroll-progress {
        position: fixed;
        top: 0;
        left: 0;
        height: 2px;
        width: 0%;
        background: var(--color-black);
        z-index: 10000;
      }

      .cursor-trail-canvas {
        position: fixed;
        inset: 0;
        z-index: 9998;
        pointer-events: none;
      }

      .back-to-top {
        position: fixed;
        bottom: 2rem;
        right: 2rem;
        width: 40px;
        height: 40px;
        color: var(--color-black);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transform: translateY(12px);
        pointer-events: none;
        transition: opacity 0.3s ease, transform 0.3s ease, background 0.3s ease;
        z-index: 100;
      }

      .back-to-top.visible {
        opacity: 1;
        transform: translateY(0);
        pointer-events: auto;
      }

      .back-to-top:hover {
        background: var(--glass-bg-hover);
      }
    </style>

    <script is:inline>
      (function () {
        // Scroll progress + back to top
        var progressBar = document.getElementById("scroll-progress");
        var btn = document.getElementById("back-to-top");

        if (progressBar && btn) {
          window.addEventListener("scroll", function () {
            var docHeight = document.documentElement.scrollHeight - window.innerHeight;
            if (docHeight > 0) {
              progressBar.style.width = (window.scrollY / docHeight) * 100 + "%";
            }
            btn.classList.toggle("visible", window.scrollY > 400);
          }, { passive: true });

          btn.addEventListener("click", function () {
            window.scrollTo({ top: 0, behavior: "smooth" });
          });
        }

        // IntersectionObserver for scroll animations
        var scrollEls = document.querySelectorAll(".scroll-animate");
        if (scrollEls.length > 0) {
          var observer = new IntersectionObserver(
            function (entries) {
              entries.forEach(function (entry) {
                if (entry.isIntersecting) {
                  entry.target.classList.add("is-visible");
                  observer.unobserve(entry.target);
                }
              });
            },
            { threshold: 0.15 }
          );
          scrollEls.forEach(function (el) { observer.observe(el); });
        }

        // Cursor trail
        if (window.matchMedia("(pointer: fine)").matches) {
          var canvas = document.getElementById("cursor-trail");
          if (canvas) {
            var ctx = canvas.getContext("2d");
            var w = canvas.width = window.innerWidth;
            var h = canvas.height = window.innerHeight;
            var cursorMoved = false;
            var mx = w / 2, my = h / 2, prevMx = mx, prevMy = my;
            var MAX_DOTS = 150;
            var dots = [];

            window.addEventListener("resize", function () {
              w = canvas.width = window.innerWidth;
              h = canvas.height = window.innerHeight;
            });

            document.addEventListener("mousemove", function (e) {
              mx = e.clientX;
              my = e.clientY;
              cursorMoved = true;
            });

            function spawn() {
              var speed = Math.hypot(mx - prevMx, my - prevMy);
              var count = Math.min(Math.floor(speed * 0.3), 5);
              for (var i = 0; i < count && dots.length < MAX_DOTS; i++) {
                var t = Math.random();
                dots.push({
                  x: prevMx + (mx - prevMx) * t,
                  y: prevMy + (my - prevMy) * t,
                  vx: (Math.random() - 0.5) * 1.2,
                  vy: (Math.random() - 0.5) * 1.2,
                  life: 1,
                  maxLife: 40 + Math.random() * 30,
                  size: 2 + Math.random() * 3.5,
                  hue: 210 + Math.random() * 40,
                });
              }
              prevMx = mx;
              prevMy = my;
            }

            function tick() {
              ctx.clearRect(0, 0, w, h);
              if (cursorMoved) {
                spawn();
                cursorMoved = false;
              }
              for (var i = dots.length - 1; i >= 0; i--) {
                var d = dots[i];
                d.x += d.vx;
                d.y += d.vy;
                d.vx *= 0.98;
                d.vy *= 0.98;
                d.life -= 1 / d.maxLife;
                if (d.life <= 0) {
                  dots[i] = dots[dots.length - 1];
                  dots.pop();
                  continue;
                }
                ctx.beginPath();
                ctx.arc(d.x, d.y, d.size * d.life, 0, Math.PI * 2);
                ctx.fillStyle = "hsla(" + d.hue + ", 70%, 60%, " + (d.life * 0.7) + ")";
                ctx.fill();
              }
              requestAnimationFrame(tick);
            }

            requestAnimationFrame(tick);
          }
        }
      })();
    </script>
  </body>
</html>
