---
import { getCollection } from "astro:content";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import TimelineItem from "../components/TimelineItem.astro";
import Base from "../layouts/Base.astro";

const experiences = (await getCollection("experience")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<Base title="About Me" description="About Sol-momma">
  <Header />
  <main class="mx-auto max-w-[800px] px-6 py-16 max-sm:px-4 max-sm:py-8">
    <section class="mb-16">
      <h1 class="mb-4 text-4xl font-bold max-sm:text-2xl">About</h1>
      <p class="text-gray leading-relaxed">
        Computer Science student specializing in full-stack development and AI
        systems, experienced in building scalable SaaS platforms and
        cloud-native applications.
      </p>
    </section>

    <section>
      <h2 class="mb-2 text-2xl font-bold">Experience</h2>
      <hr class="border-gray-light mb-12" />

      <div class="relative">
        <div
          class="bg-gray-dark absolute top-0 left-1/2 h-full w-[3px] -translate-x-1/2"
        >
        </div>

        {
          experiences.map((exp, i) => (
            <TimelineItem
              name={exp.data.name}
              role={exp.data.role}
              period={exp.data.period}
              side={i % 2 === 0 ? "left" : "right"}
            />
          ))
        }
      </div>
    </section>
  </main>
  <Footer />
</Base>
