---
import BaseHead from "../../components/BaseHead.astro";
import CanvasFrame from "../../components/three/CanvasFrame.astro";
import { SITE_TITLE } from "../../consts";
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseHead
      title={`Scroll Story — Experiments — ${SITE_TITLE}`}
      description="scroll で 3 シーンを巡る。"
    />
  </head>
  <body>
    <a class="back glass" href="/experiments">← Experiments</a>
    <CanvasFrame demo="scroll-story" />
    <div class="scroll-spacer" aria-hidden="true"></div>

    <style is:global>
      html,
      body {
        margin: 0;
        padding: 0;
        height: 100%;
        background: var(--t-bg);
      }
      body {
        overflow-y: scroll;
      }
    </style>
    <style>
      .back {
        position: fixed;
        top: 1.5rem;
        left: 1.5rem;
        z-index: 10;
        padding: 0.5rem 1rem;
        border-radius: 9999px;
        text-decoration: none;
        color: var(--t-text);
        font-family: inherit;
        font-size: 0.95rem;
      }
      .scroll-spacer {
        height: 300vh;
        pointer-events: none;
      }
    </style>
  </body>
</html>
