---
import Header from "../components/Header.astro";
import SocialLinks from "../components/SocialLinks.astro";
import Base from "../layouts/Base.astro";
---

<Base>
  <Header />
  <main
    class="flex min-h-[calc(100vh-60px)] flex-col items-center justify-center px-6"
  >
    <div
      class="bg-gray-light mb-8 h-56 w-56 overflow-hidden rounded-full max-sm:h-40 max-sm:w-40"
    >
      <div
        class="text-gray flex h-full w-full items-center justify-center text-6xl max-sm:text-4xl"
      >
      </div>
    </div>

    <h1 class="mb-1 text-4xl font-bold max-sm:text-2xl">@Sol-momma</h1>
    <p class="text-gray mb-8 text-lg">Software Engineer</p>

    <SocialLinks
      class="flex items-center gap-5"
      linkClass="text-gray transition-colors hover:text-black"
    />
  </main>
</Base>
