---
import SocialLinks from "./SocialLinks.astro";

const today = new Date();
---

<footer
  class="text-gray px-4 pt-8 pb-24 text-center"
  style="background: linear-gradient(rgba(229, 233, 240, 50%), #fff) no-repeat;"
>
  &copy; {today.getFullYear()} Sol-momma
  <SocialLinks
    class="mt-4 flex justify-center gap-4"
    linkClass="text-gray no-underline hover:text-gray-dark"
  />
</footer>
