---
---

<canvas id="kamishibai-bg"></canvas>

<style is:global>
  body:has(#kamishibai-bg) {
    background: transparent !important;
    /* Force dark-compatible colors regardless of light/dark mode */
    --t-black: rgb(230, 228, 220);
    --t-gray: rgb(150, 148, 140);
    --t-accent: rgb(220, 218, 210);
    --glass-bg: rgba(255, 255, 255, 0.08);
    --glass-bg-hover: rgba(255, 255, 255, 0.14);
    --glass-border: rgba(255, 255, 255, 0.16);
    --glass-shadow: rgba(0, 0, 0, 0.25);
    --glass-highlight: rgba(255, 255, 255, 0.22);
  }
  #kamishibai-bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    width: 100vw;
    height: 100vh;
    pointer-events: none;
    display: block;
  }
</style>

<script>
  import * as THREE from "three";

  const isMobile = window.matchMedia("(pointer: coarse)").matches;
  const N = isMobile ? 1200 : 3000;

  function hash(n: number): number {
    return (((Math.sin(n * 127.1 + 311.7) * 43758.5453) % 1) + 1) % 1;
  }

  function makeScenePositions(scene: number): Float32Array {
    const pos = new Float32Array(N * 3);
    for (let i = 0; i < N; i++) {
      const s0 = hash(i * 3.0);
      const s1 = hash(i * 3.0 + 1.0);
      const s2 = hash(i * 3.0 + 2.0);
      let x = 0,
        y = 0,
        z = 0;

      if (scene === 0) {
        // void: scattered sphere
        const r = Math.cbrt(s2) * 3.5;
        const phi = Math.acos(2 * s0 - 1);
        const theta = s1 * Math.PI * 2;
        x = r * Math.sin(phi) * Math.cos(theta);
        y = r * Math.cos(phi);
        z = r * Math.sin(phi) * Math.sin(theta);
      } else if (scene === 1) {
        // discovery: helix / code stream
        const t = i / N;
        x = (t - 0.5) * 8.0;
        y = Math.sin(t * Math.PI * 8) * 1.2 + (s0 - 0.5) * 0.3;
        z = Math.cos(t * Math.PI * 8) * 1.2 + (s1 - 0.5) * 0.3;
      } else if (scene === 2) {
        // formation: sphere surface
        const phi2 = Math.acos(2 * s0 - 1);
        const theta2 = s1 * Math.PI * 2;
        const r2 = 2.0 + s2 * 0.1;
        x = r2 * Math.sin(phi2) * Math.cos(theta2);
        y = r2 * Math.cos(phi2);
        z = r2 * Math.sin(phi2) * Math.sin(theta2);
      } else if (scene === 3) {
        // explosion: burst outward from sphere
        const phi3 = Math.acos(2 * s0 - 1);
        const theta3 = s1 * Math.PI * 2;
        const rBurst = 1.5 + s2 * 4.5;
        x = rBurst * Math.sin(phi3) * Math.cos(theta3);
        y = rBurst * Math.cos(phi3);
        z = rBurst * Math.sin(phi3) * Math.sin(theta3);
      } else {
        // home: spiral layers
        const t4 = i / N;
        const layer = Math.floor(t4 * 15);
        const inLayer = (t4 * 15) % 1;
        const angle = inLayer * Math.PI * 2 + layer * 0.7;
        const radius = 0.5 + (layer / 15) * 2.5;
        x = radius * Math.cos(angle);
        y = (layer / 15 - 0.5) * 5.0;
        z = radius * Math.sin(angle);
      }

      pos[i * 3] = x;
      pos[i * 3 + 1] = y;
      pos[i * 3 + 2] = z;
    }
    return pos;
  }

  const BG_COLORS = [
    new THREE.Color(0x0c0a14), // void: deep purple
    new THREE.Color(0x071220), // discovery: deep navy
    new THREE.Color(0x180d04), // formation: deep amber
    new THREE.Color(0x140818), // explosion: deep rose
    new THREE.Color(0x100e0c), // home: warm near-black
  ];

  const PARTICLE_COLORS = [
    new THREE.Color(0x8080ff), // void: blue-purple
    new THREE.Color(0x40c0ff), // discovery: cyan
    new THREE.Color(0xffb040), // formation: amber-gold
    new THREE.Color(0xff6080), // explosion: rose-red
    new THREE.Color(0xffd080), // home: warm yellow
  ];

  function lerpColor(colors: THREE.Color[], progress: number): THREE.Color {
    const s = Math.min(Math.max(Math.floor(progress), 0), colors.length - 2);
    const t = Math.min(Math.max(progress - s, 0), 1);
    return colors[s].clone().lerp(colors[s + 1], t);
  }

  const canvas = document.getElementById("kamishibai-bg") as HTMLCanvasElement;
  const renderer = new THREE.WebGLRenderer({ canvas, antialias: true });
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, isMobile ? 1.5 : 2));
  renderer.setSize(window.innerWidth, window.innerHeight);

  const threeScene = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(
    60,
    window.innerWidth / window.innerHeight,
    0.1,
    100,
  );
  camera.position.z = 5;

  const geometry = new THREE.BufferGeometry();
  const rands = new Float32Array(N);
  for (let i = 0; i < N; i++) rands[i] = hash(i * 17.0 + 0.42);

  geometry.setAttribute(
    "position",
    new THREE.BufferAttribute(makeScenePositions(0), 3),
  );
  geometry.setAttribute(
    "aPos0",
    new THREE.BufferAttribute(makeScenePositions(0), 3),
  );
  geometry.setAttribute(
    "aPos1",
    new THREE.BufferAttribute(makeScenePositions(1), 3),
  );
  geometry.setAttribute(
    "aPos2",
    new THREE.BufferAttribute(makeScenePositions(2), 3),
  );
  geometry.setAttribute(
    "aPos3",
    new THREE.BufferAttribute(makeScenePositions(3), 3),
  );
  geometry.setAttribute(
    "aPos4",
    new THREE.BufferAttribute(makeScenePositions(4), 3),
  );
  geometry.setAttribute("aRand", new THREE.BufferAttribute(rands, 1));

  const vertexShader = `
    uniform float u_time;
    uniform float u_progress;
    uniform vec3 u_color;

    attribute vec3 aPos0;
    attribute vec3 aPos1;
    attribute vec3 aPos2;
    attribute vec3 aPos3;
    attribute vec3 aPos4;
    attribute float aRand;

    varying float vAlpha;
    varying vec3 vColor;

    vec3 pickPos(int idx) {
      if (idx == 0) return aPos0;
      if (idx == 1) return aPos1;
      if (idx == 2) return aPos2;
      if (idx == 3) return aPos3;
      return aPos4;
    }

    // TODO: シーン遷移のイージング関数を実装してください
    // t: 0.0 → 1.0 (生のシーン進捗)
    // return: 0.0 → 1.0 (スムージング済み)
    float easeTransition(float t) {
      return t; // ← ここを変えてみてください
    }

    void main() {
      float p = clamp(u_progress, 0.0, 4.0);
      int s = int(floor(p));
      int nextS = int(min(float(s + 1), 4.0));
      float rawT = fract(p);

      vec3 from = pickPos(s);
      vec3 to   = pickPos(nextS);
      vec3 base = mix(from, to, easeTransition(rawT));

      float phase = aRand * 6.28318;
      vec3 idle = vec3(
        sin(u_time * 0.4 + phase) * 0.06,
        cos(u_time * 0.3 + phase + 1.0) * 0.06,
        sin(u_time * 0.5 + phase + 2.0) * 0.04
      );

      vec3 finalPos = base + idle;

      gl_Position = projectionMatrix * modelViewMatrix * vec4(finalPos, 1.0);

      float dist = length(gl_Position.xyz / gl_Position.w);
      gl_PointSize = clamp(mix(1.5, 4.5, aRand) * (4.0 / (1.0 + dist * 2.0)), 1.0, 6.0);

      vAlpha = mix(0.25, 0.85, aRand);
      vColor = u_color;
    }
  `;

  const fragmentShader = `
    varying float vAlpha;
    varying vec3 vColor;

    void main() {
      vec2 uv = gl_PointCoord - 0.5;
      float d = length(uv);
      if (d > 0.5) discard;
      float alpha = vAlpha * (1.0 - smoothstep(0.1, 0.5, d) * 1.3);
      gl_FragColor = vec4(vColor, alpha);
    }
  `;

  const material = new THREE.ShaderMaterial({
    uniforms: {
      u_time: { value: 0 },
      u_progress: { value: 0 },
      u_color: { value: new THREE.Color(0x8080ff) },
    },
    vertexShader,
    fragmentShader,
    transparent: true,
    blending: THREE.AdditiveBlending,
    depthWrite: false,
  });

  const points = new THREE.Points(geometry, material);
  threeScene.add(points);

  let camAngle = 0;
  let targetProgress = 0;
  let currentProgress = 0;

  function updateProgress() {
    const maxScroll = Math.max(
      1,
      document.documentElement.scrollHeight - window.innerHeight,
    );
    targetProgress = (window.scrollY / maxScroll) * 4.0;
  }

  window.addEventListener("scroll", updateProgress, { passive: true });
  updateProgress();

  window.addEventListener(
    "resize",
    () => {
      camera.aspect = window.innerWidth / window.innerHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(window.innerWidth, window.innerHeight);
    },
    { passive: true },
  );

  const clock = new THREE.Clock();

  function animate() {
    requestAnimationFrame(animate);
    const elapsed = clock.getElapsedTime();

    currentProgress += (targetProgress - currentProgress) * 0.04;

    material.uniforms.u_time.value = elapsed;
    material.uniforms.u_progress.value = currentProgress;
    material.uniforms.u_color.value = lerpColor(PARTICLE_COLORS, currentProgress);

    renderer.setClearColor(lerpColor(BG_COLORS, currentProgress), 1.0);

    camAngle += 0.0003;
    camera.position.x = Math.sin(camAngle) * 0.5;
    camera.position.y = Math.cos(camAngle * 0.7) * 0.2;
    camera.lookAt(0, 0, 0);

    renderer.render(threeScene, camera);
  }

  animate();
</script>
