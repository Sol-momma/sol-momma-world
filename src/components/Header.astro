---
import HeaderLink from "./HeaderLink.astro";
---

<header class="m-0 bg-transparent px-4">
  <nav class="flex items-center justify-end">
    <div>
      <HeaderLink
        href="/"
        class="border-b-4 border-transparent px-2 py-4 text-black no-underline"
        >Home</HeaderLink
      >
      <HeaderLink
        href="/blog"
        class="border-b-4 border-transparent px-2 py-4 text-black no-underline"
        >Blog</HeaderLink
      >
      <HeaderLink
        href="/about"
        class="border-b-4 border-transparent px-2 py-4 text-black no-underline"
        >About</HeaderLink
      >
    </div>
  </nav>
</header>
